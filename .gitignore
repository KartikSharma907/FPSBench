# ---------------------------------------------------------------------------
# FPS-Bench .gitignore
# ---------------------------------------------------------------------------

# Prepared / derived media and results are user-side artifacts; never commit.
data/
cache/
downloaded_videos/
downloaded_videos_tc/
results/
frames/
*.mp4
*.webm
*.mkv

# Secrets / tokens
.env
*.hf_token
*.pem

# Leaderboard runtime store (persisted to the HF results dataset in production)
leaderboard/results.jsonl

# Python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/

# ---------------------------------------------------------------------------
# Research / scratch files (NOT part of the public release). These live in the
# working tree for the authors but must not be published.
# ---------------------------------------------------------------------------
run_*_benchmark.py
streamlit_quiz.py
add_categories_v2.py
categorized_videos.csv
task.md
*.xlsx
fpsbench-release/
CVPR2026__FPSBench/
*.pdf

# Editor / OS
.DS_store
.idea
